{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"paths": {
			"pillo": ["../packages/react/src/index.ts"],
			"pillo/styles.css": ["../packages/core/src/styles.css"],
			"@pillo/core": ["../packages/core/src/index.ts"]
		}
	},
	"include": ["."]
}
