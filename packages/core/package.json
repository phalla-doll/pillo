{
	"name": "@pillo/core",
	"version": "0.4.0",
	"description": "Framework-agnostic toast store, imperative API, and stylesheet for Pillo.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/phalla-doll/pillo.git",
		"directory": "packages/core"
	},
	"sideEffects": ["**/*.css", "./dist/styles.css"],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "rm -rf dist && bunchee && cp src/styles.css dist/styles.css",
		"dev": "bunchee --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	}
}
