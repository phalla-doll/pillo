{
	"name": "pillo-workspace",
	"private": true,
	"description": "Monorepo for Pillo — a physics-based toast library.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/phalla-doll/pillo.git"
	},
	"workspaces": ["packages/*", "playground"],
	"scripts": {
		"build": "bun run --filter='@pillo/core' build && bun run --filter='pillo' build",
		"dev": "bun run --filter='pillo' dev",
		"typecheck": "bun run --filter='*' typecheck",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^2.1.0",
		"bunchee": "^6.9.4",
		"typescript": "^5.5.0",
		"vitest": "^2.1.0"
	}
}
